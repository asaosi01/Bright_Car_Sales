-- how many cars were sold each year
SELECT year,
        COUNT(year) AS Year_of_Sales
FROM workspace.default.car_sales
GROUP BY year
ORDER BY year;


-- how many cars were sold each year and which make, handle NULLs
SELECT year,
       CASE WHEN make IS NULL THEN 'ford escort' ELSE make END AS make,
       model,
       COUNT(year) AS Year_of_Sales
FROM workspace.default.car_sales
GROUP BY year, make, model
ORDER BY year;

-- how many cars were sold each year and which model, handle NULLs
SELECT year, 
       CASE 
          WHEN (year between 1980 and 1990) and model IS NULL THEN 'L 90s' 
          WHEN (year between 1991 and 2000) and model IS NULL THEN 'LX' 
          WHEN (year between 2001 and 2010) and model IS NULL THEN 'Sport GT' 
          WHEN year > 2010 and model IS NULL THEN 'Focus' 
       ELSE model END AS model,
       COUNT(year) AS Year_of_Sales
FROM workspace.default.car_sales
GROUP BY year, model
ORDER BY year;

-- how many cars were sold each year and trim discription, handle NULLs
SELECT year, 
        CASE WHEN trim IS NULL THEN 'unknown' ELSE trim END AS trim,
        COUNT(year) AS Year_of_Sales
FROM workspace.default.car_sales
GROUP BY year, trim
ORDER BY year;

-- max revenue
SELECT MAX(sellingprice) AS MAX_Sales
FROM workspace.default.car_sales;

-- revenue by year
SELECT year,  
      SUM(sellingprice) AS Revenue
FROM workspace.default.car_sales
GROUP BY year
ORDER BY Revenue DESC;

-- Avg sellingprice
SELECT year,  
      AVG(sellingprice) AS AvgPrice
FROM workspace.default.car_sales
GROUP BY year
ORDER BY AvgPrice DESC;

-- Convert saledate from text to formatted date (remove day-of-week prefix first)
SELECT 
     DATE_FORMAT(
     TO_TIMESTAMP(SUBSTRING(saledate, 5), 'MMM dd yyyy HH:mm:ss'),
    'dd MMM yyyy'
  ) AS saledate
FROM workspace.default.car_sales;

--========================================================================================================================================
-- Final code
SELECT year,
       CASE WHEN make IS NULL THEN 'ford escort' ELSE make END AS make, 
        CASE 
          WHEN (year between 1980 and 1990) and model IS NULL THEN 'L 90s' 
          WHEN (year between 1991 and 2000) and model IS NULL THEN 'LX' 
          WHEN (year between 2001 and 2010) and model IS NULL THEN 'Sport GT' 
          WHEN year > 2010 and model IS NULL THEN 'Focus' 
       ELSE model END AS model,
       CASE WHEN trim IS NULL AND trim in ('+','!') THEN 'unknown' ELSE trim END AS trim,
       body,
       CASE WHEN transmission IS NULL THEN 'hybrid' ELSE transmission END AS transmission,
       vin,
       state,
       COALESCE(condition, '6') AS condition,
       odometer, 
       COALESCE(NULLIF(color, '—'), 'gold') AS color, 
       COALESCE(NULLIF(color, '—'), 'light gray') AS interior, 
       seller, 
       COALESCE(mmr, '20') AS mmr, 
       COALESCE(NULLIF(sellingprice, 1), 55500) AS sellingprice, 
       CASE 
       WHEN saledate IS NULL THEN 
          DATE_FORMAT(
              MAKE_DATE(year, MONTH(current_date()), DAY(current_date())),
              'dd MMM yyyy'
          )
       ELSE DATE_FORMAT(
              TO_TIMESTAMP(SUBSTRING(saledate, 5), 'MMM dd yyyy HH:mm:ss'),
              'dd MMM yyyy'
          )
       END AS saledate
FROM workspace.default.car_sales;
